<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Menú Principal</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: Arial, sans-serif;
}

body{
    background:#f4f4f4;
}

header{
    background:#1f2937;
    padding:15px 30px;
}

.navbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.logo{
    color:white;
    font-size:24px;
    font-weight:bold;
}

.menu{
    list-style:none;
    display:flex;
    gap:25px;
}

.menu li a{
    text-decoration:none;
    color:white;
    font-size:16px;
    transition:0.3s;
}

.menu li a:hover{
    color:#60a5fa;
}

.btn-login{
    background:#2563eb;
    color:white;
    padding:8px 15px;
    border-radius:5px;
}

.btn-login:hover{
    background:#1d4ed8;
    color:white;
}

.hero{
    text-align:center;
    padding:100px 20px;
}

.hero h1{
    font-size:48px;
    color:#1f2937;
}

.hero p{
    margin-top:15px;
    color:#555;
    font-size:18px;
}
</style>
</head>

<body>

<header>
    <nav class="navbar">
        <div class="logo">Mi Sitio</div>

        <ul class="menu">
            <li><a href="#">Inicio</a></li>
            <li><a href="#">Productos</a></li>
            <li><a href="#">Servicios</a></li>
            <li><a href="#">Nosotros</a></li>
            <li><a href="#">Contacto</a></li>
            <li><a href="#" class="btn-login">Iniciar Sesión</a></li>
        </ul>
    </nav>
</header>

<section class="hero">
    <h1>Bienvenido a Mi Sitio Web</h1>
    <p>Diseño moderno para tu página principal.</p>
</section>

</body>
</html>
